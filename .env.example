# 9Router Proxy local OpenAI-compatible endpoint.
ROUTER_BASE_URL=http://localhost:20128/v1
ROUTER_API_KEY=dummy
# Some 9Router pools block the OpenAI Python SDK default User-Agent.
ROUTER_USER_AGENT=python-httpx/0.28.1

# ════════════════════════════════════════════════════════════════════
#  12-AGENT CODING PIPELINE — 9Router model assignment
# ════════════════════════════════════════════════════════════════════
#
#  Non-code/light/static: cx/gpt-5.4-mini
#  Code/default:          cx/gpt-5.5
#  Review/deep fallback:  cx/gpt-5.5-review
#  5.6 models are kept as late spares only because they are expensive.
# ════════════════════════════════════════════════════════════════════

MODEL_MANAGER=cx/gpt-5.4-mini
MODEL_SYNTHESIZER=cx/gpt-5.4-mini
MODEL_INTEGRITY=cx/gpt-5.5-review
MODEL_SCANNER=cx/gpt-5.4-mini
MODEL_ANALYZER=cx/gpt-5.5-review
MODEL_CODE_A=cx/gpt-5.5
MODEL_CODE_B=cx/gpt-5.5-review
MODEL_REVIEWER=cx/gpt-5.5-review
MODEL_TESTER=cx/gpt-5.5
MODEL_SECURITY=cx/gpt-5.5-review
MODEL_DEBUGGER=cx/gpt-5.5
MODEL_WORKER=cx/gpt-5.4-mini

# ── Support toolbox settings ─────────────────────────────────────────
# Spare deployments — fallback khi rate-limit/timeout dai dẳng (thứ tự ưu tiên)
# Chỉ các deployment có trong 12 role hoặc HARNESS_KNOWN_DEPLOYMENTS mới được thử.
SPARE_MODELS=cx/gpt-5.4-mini,cx/gpt-5.5,cx/gpt-5.5-review,cx/gpt-5.6-sol,cx/gpt-5.6-sol-review
HARNESS_KNOWN_DEPLOYMENTS=cx/gpt-5.6-sol,cx/gpt-5.6-sol-review,cx/gpt-5.6-terra,cx/gpt-5.6-terra-review,cx/gpt-5.6-luna,cx/gpt-5.6-luna-review,cx/gpt-5.5,cx/gpt-5.5-review,cx/gpt-5.4,cx/gpt-5.4-review,cx/gpt-5.4-mini

# Root folder mà support tools được phép đọc file (panel_review, ask_codebase...)
# Để trống = thư mục chạy mcp_server.py. Nên trỏ vào repo đang làm việc.
WORKSPACE_ROOT=

# Limits
MAX_OUTPUT_TOKENS=16384
MAX_RETRIES=1
REQUEST_TIMEOUT=180
HARNESS_RESPONSES_MAX_WORKERS=6

# Runtime feature control file. Empty = project ./harness.features.json,
# then harness install ./harness.features.json. Set a custom file for a
# temporary profile; if that file is missing/malformed, env below is used.
HARNESS_FEATURES_FILE=
HARNESS_LLM_ENABLED=1
HARNESS_FINOPS_ENABLED=1
HARNESS_HOOKS_ENABLED=1
HARNESS_LESSONS_ENABLED=1
HARNESS_AUTO_PILOT=1
HARNESS_AUTO_MODE=safe
HARNESS_STATIC_LLM=0
HARNESS_AUTO_LLM=0
HARNESS_AUTO_WATCH=0
HARNESS_AUTO_WATCH_MODE=safe
HARNESS_AUTO_WATCH_LLM=0
HARNESS_AUTO_WATCH_INTERVAL=3
HARNESS_AUTO_WATCH_DEBOUNCE=2

# Heavy role budgets
ROLE_TIMEOUT_MANAGER=420
ROLE_TIMEOUT_SYNTHESIZER=180
ROLE_TIMEOUT_INTEGRITY=300
ROLE_TIMEOUT_REVIEWER=150
ROLE_TIMEOUT_TESTER=150
ROLE_TIMEOUT_SECURITY=150
ROLE_TIMEOUT_SCANNER=120

# ask_codebase: read broad context, relevance-prune before 9Router, fail fast to useful local fallback
HARNESS_ASK_CODEBASE_TIMEOUT=45
HARNESS_ASK_CODEBASE_MODEL_CHAIN=cx/gpt-5.4-mini,cx/gpt-5.5,cx/gpt-5.5-review
HARNESS_ASK_CODEBASE_LOAD_BYTES=2500000
HARNESS_ASK_CODEBASE_CONTEXT_BYTES=220000
HARNESS_ASK_CODEBASE_MAX_OUTPUT_TOKENS=8192
HARNESS_ASK_CODEBASE_USE_SPARES=0
HARNESS_ASK_CODEBASE_TIMEOUT_RETRIES=0
HARNESS_ASK_CODEBASE_INCLUDE_WIKI=0
