# Azure AI Foundry credentials
# Model inference endpoint (chat completions): *.services.ai.azure.com/models
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/models
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_API_VERSION=2024-05-01-preview

# Responses API — dòng pro/codex chỉ chạy API này (host cognitiveservices, cùng key)
# Để trống = tự suy ra từ AZURE_OPENAI_ENDPOINT
AZURE_RESPONSES_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_RESPONSES_API_VERSION=2025-04-01-preview

# ════════════════════════════════════════════════════════════════════
#  12-AGENT CODING PIPELINE — Capability Assignment
# ════════════════════════════════════════════════════════════════════
#
#  ORCHESTRATION
#  MODEL_MANAGER      → gpt-5.4-pro-3     long-context codebase Q&A (ask_codebase)
#  MODEL_SYNTHESIZER  → gpt-5.4-4         fast JSON merge/dedupe
#
#  ANALYSIS
#  MODEL_ANALYZER     → grok-4-20-reasoning  requirements → design
#
#  CODE (dual parallel ⭐)
#  MODEL_CODE_A       → gpt-5.3-codex     primary code-focused proposal
#  MODEL_CODE_B       → gpt-5.4           secondary / alt approach
#
#  REVIEW (3x codex, all parallel → integrity sequential)
#  MODEL_REVIEWER     → gpt-5.3-codex     bugs, quality
#  MODEL_TESTER       → gpt-5.3-codex-2   unit/integration tests
#  MODEL_SECURITY     → gpt-5.3-codex-3   OWASP, vulns
#  MODEL_INTEGRITY    → gpt-5.3-codex-4   high-TPM data integrity + final synthesis
#  MODEL_SCANNER      → gpt-5.3-codex-4   high-TPM static analysis: dead_code/perf_regression, temp=0.0
#
#  FIX
#  MODEL_DEBUGGER     → gpt-5.4-2         apply all fixes
#
#  WORKER
#  MODEL_WORKER       → gpt-5.4-mini      format, docs, boilerplate
#
#  SPARE (rate-limit/timeout overflow): fast stable models first
# ════════════════════════════════════════════════════════════════════

MODEL_MANAGER=gpt-5.4-pro-3
MODEL_SYNTHESIZER=gpt-5.4-4
MODEL_INTEGRITY=gpt-5.3-codex-4
MODEL_SCANNER=gpt-5.3-codex-4
MODEL_ANALYZER=grok-4-20-reasoning
MODEL_CODE_A=gpt-5.3-codex
MODEL_CODE_B=gpt-5.4
MODEL_REVIEWER=gpt-5.3-codex
MODEL_TESTER=gpt-5.3-codex-2
MODEL_SECURITY=gpt-5.3-codex-3
MODEL_DEBUGGER=gpt-5.4-2
MODEL_WORKER=gpt-5.4-mini

# ── Support toolbox settings ─────────────────────────────────────────
# Spare deployments — fallback khi rate-limit/timeout dai dẳng (thứ tự ưu tiên)
# Chỉ các deployment có trong 12 role hoặc HARNESS_KNOWN_DEPLOYMENTS mới được thử.
SPARE_MODELS=gpt-5.4-4,gpt-5.4-3,gpt-5.3-codex-4,gpt-5.4,gpt-5.4-2,gpt-4.1-mini
HARNESS_KNOWN_DEPLOYMENTS=gpt-4.1-mini

# Root folder mà support tools được phép đọc file (panel_review, ask_codebase...)
# Để trống = thư mục chạy mcp_server.py. Nên trỏ vào repo đang làm việc.
WORKSPACE_ROOT=

# Limits
MAX_OUTPUT_TOKENS=16384
MAX_RETRIES=1
REQUEST_TIMEOUT=180
HARNESS_RESPONSES_MAX_WORKERS=6
HARNESS_AUTO_PILOT=1
HARNESS_AUTO_MODE=max
HARNESS_STATIC_LLM=1
HARNESS_AUTO_WATCH=1
HARNESS_AUTO_WATCH_INTERVAL=3
HARNESS_AUTO_WATCH_DEBOUNCE=2

# Heavy role budgets
ROLE_TIMEOUT_MANAGER=420
ROLE_TIMEOUT_SYNTHESIZER=180
ROLE_TIMEOUT_INTEGRITY=300
ROLE_TIMEOUT_REVIEWER=150
ROLE_TIMEOUT_TESTER=150
ROLE_TIMEOUT_SECURITY=150
ROLE_TIMEOUT_SCANNER=120

# ask_codebase: read broad context, relevance-prune before Azure, fail fast to useful local fallback
HARNESS_ASK_CODEBASE_TIMEOUT=45
HARNESS_ASK_CODEBASE_LOAD_BYTES=2500000
HARNESS_ASK_CODEBASE_CONTEXT_BYTES=220000
HARNESS_ASK_CODEBASE_MAX_OUTPUT_TOKENS=8192
HARNESS_ASK_CODEBASE_USE_SPARES=0
HARNESS_ASK_CODEBASE_TIMEOUT_RETRIES=0
HARNESS_ASK_CODEBASE_INCLUDE_WIKI=0
