# 9Router Proxy local OpenAI-compatible endpoint.
ROUTER_BASE_URL=http://localhost:0931289317
ROUTER_API_KEY=dummy

# ════════════════════════════════════════════════════════════════════
#  12-AGENT CODING PIPELINE — 9Router model assignment
# ════════════════════════════════════════════════════════════════════
#
#  Non-code/light: ag/gemini-3.5-flash-extra-low
#  Code/high:      ag/gemini-3-flash-agent
#  Deep/code:      ag/claude-sonnet-4-6
# ════════════════════════════════════════════════════════════════════

MODEL_MANAGER=ag/gemini-3-flash-agent
MODEL_SYNTHESIZER=ag/gemini-3-flash-agent
MODEL_INTEGRITY=ag/claude-sonnet-4-6
MODEL_SCANNER=ag/gemini-3-flash-agent
MODEL_ANALYZER=ag/claude-sonnet-4-6
MODEL_CODE_A=ag/gemini-3-flash-agent
MODEL_CODE_B=ag/claude-sonnet-4-6
MODEL_REVIEWER=ag/gemini-3-flash-agent
MODEL_TESTER=ag/gemini-3-flash-agent
MODEL_SECURITY=ag/claude-sonnet-4-6
MODEL_DEBUGGER=ag/gemini-3-flash-agent
MODEL_WORKER=ag/gemini-3.5-flash-extra-low

# ── Support toolbox settings ─────────────────────────────────────────
# Spare deployments — fallback khi rate-limit/timeout dai dẳng (thứ tự ưu tiên)
# Chỉ các deployment có trong 12 role hoặc HARNESS_KNOWN_DEPLOYMENTS mới được thử.
SPARE_MODELS=ag/gemini-3-flash-agent,ag/gemini-3.5-flash-extra-low,ag/claude-sonnet-4-6
HARNESS_KNOWN_DEPLOYMENTS=ag/gemini-3-flash-agent,ag/gemini-3.5-flash-extra-low,ag/claude-sonnet-4-6

# Root folder mà support tools được phép đọc file (panel_review, ask_codebase...)
# Để trống = thư mục chạy mcp_server.py. Nên trỏ vào repo đang làm việc.
WORKSPACE_ROOT=

# Limits
MAX_OUTPUT_TOKENS=16384
MAX_RETRIES=1
REQUEST_TIMEOUT=180
HARNESS_RESPONSES_MAX_WORKERS=6

# Runtime feature control file. Empty = project ./harness.features.json,
# then harness install ./harness.features.json. Set a custom file for a
# temporary profile; if that file is missing/malformed, env below is used.
HARNESS_FEATURES_FILE=
HARNESS_LLM_ENABLED=1
HARNESS_FINOPS_ENABLED=1
HARNESS_HOOKS_ENABLED=1
HARNESS_LESSONS_ENABLED=1
HARNESS_AUTO_PILOT=1
HARNESS_AUTO_MODE=safe
HARNESS_STATIC_LLM=0
HARNESS_AUTO_LLM=0
HARNESS_AUTO_WATCH=0
HARNESS_AUTO_WATCH_MODE=safe
HARNESS_AUTO_WATCH_LLM=0
HARNESS_AUTO_WATCH_INTERVAL=3
HARNESS_AUTO_WATCH_DEBOUNCE=2

# Quota reminder (read-only). Does not block model calls.
# If monthly limits are set, router_quota_status reports remaining local/router budget.
HARNESS_QUOTA_MONTHLY_TOKENS=
HARNESS_QUOTA_MONTHLY_USD=
HARNESS_QUOTA_WARN_PCT=80
HARNESS_QUOTA_CRITICAL_PCT=95
# Optional: override 9Router usage endpoint(s), comma-separated full URLs.
HARNESS_ROUTER_QUOTA_ENDPOINT=
# Optional: comma-separated 9Router connection IDs for provider/account quota probes.
HARNESS_ROUTER_QUOTA_CONNECTION_IDS=
# Optional: separate API key for dashboard quota endpoints; defaults to ROUTER_API_KEY.
HARNESS_ROUTER_QUOTA_API_KEY=
# Optional: 9Router dashboard auth, if /api/usage/* returns 401.
HARNESS_ROUTER_QUOTA_BEARER=
HARNESS_ROUTER_QUOTA_COOKIE=
HARNESS_ROUTER_QUOTA_HEADERS_JSON=

# Heavy role budgets
ROLE_TIMEOUT_MANAGER=420
ROLE_TIMEOUT_SYNTHESIZER=180
ROLE_TIMEOUT_INTEGRITY=300
ROLE_TIMEOUT_REVIEWER=150
ROLE_TIMEOUT_TESTER=150
ROLE_TIMEOUT_SECURITY=150
ROLE_TIMEOUT_SCANNER=120

# ask_codebase: read broad context, relevance-prune before 9Router, fail fast to useful local fallback
HARNESS_ASK_CODEBASE_TIMEOUT=45
HARNESS_ASK_CODEBASE_LOAD_BYTES=2500000
HARNESS_ASK_CODEBASE_CONTEXT_BYTES=220000
HARNESS_ASK_CODEBASE_MAX_OUTPUT_TOKENS=8192
HARNESS_ASK_CODEBASE_USE_SPARES=0
HARNESS_ASK_CODEBASE_TIMEOUT_RETRIES=0
HARNESS_ASK_CODEBASE_INCLUDE_WIKI=0
